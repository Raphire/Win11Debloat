                                            <TextBlock x:Name="AppSearchPlaceholder" Grid.Column="1" Text="%LANG:AppSearchPlaceholder%" Foreground="{DynamicResource FgColor}" Opacity="0.5" FontSize="13" Margin="3,0,0,1" VerticalAlignment="Center" IsHitTestVisible="False"/>
